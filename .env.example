# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

# Public URL - Safe to expose to client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable/Anonymous Key - Safe to expose to client
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================
# CRITICAL: NEVER commit the actual values below to version control
# These should ONLY be set in your deployment environment (Vercel, etc.)

# Database connection string with password
# Format: postgresql://postgres.[PROJECT-ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Supabase Secret Key (new format: sb_secret_xxx)
# WARNING: This key bypasses Row Level Security - NEVER expose to client
# Get this from: Supabase Dashboard > Settings > API > Secret Key
DATABASE_SECRET_KEY=sb_secret_your_secret_key_here

# ============================================
# ADMIN AUTHORIZATION (RBAC) & SITE CONFIGURATION
# ============================================
# Comma-separated list of admin email addresses
# Only these emails will have access to admin functions
# Example: ADMIN_EMAILS=admin@example.com,owner@example.com
ADMIN_EMAILS=your-admin-email@example.com

# Production site URL (no trailing slash) - Used for QR codes, links, and SEO redirects.
# If unset, defaults to http://localhost:3000 in development.
NEXT_PUBLIC_SITE_URL=https://irnk.codes

# ============================================
# CONTACT EMAIL DELIVERY (RESEND)
# ============================================
# Server-only API key from Resend. NEVER expose as NEXT_PUBLIC_*.
RESEND_API_KEY=re_your_resend_api_key_here

# Recipient for contact form notifications. Falls back to first ADMIN_EMAILS value.
CONTACT_TO_EMAIL=owner@example.com

# Production should use a verified Resend domain sender.
RESEND_FROM_EMAIL="IRNK Codes <hello@example.com>"

# Optional submitter confirmation email.
CONTACT_AUTO_REPLY_ENABLED=false

# ============================================
# AI ARTICLE GENERATION (GOOGLE GEMINI)
# ============================================
# Server-only Google AI Studio key. NEVER expose as NEXT_PUBLIC_*.
GOOGLE_GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional Gemini model override.
GOOGLE_GEMINI_MODEL=gemini-1.5-flash

# ============================================
# BLOG THUMBNAIL STORAGE
# ============================================
# Blog thumbnails use the existing public `media` bucket under:
# blog/thumbnails/{slug}/{timestamp}-{filename}
# File size and MIME limits are enforced by the Supabase Storage bucket policy.

# ============================================
# SEO VERIFICATION CODES
# ============================================
# Optional: Add your verification codes for search engines

NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code
NEXT_PUBLIC_BING_VERIFICATION=your-bing-verification-code
NEXT_PUBLIC_YANDEX_VERIFICATION=your-yandex-verification-code

# ============================================
# SECURITY NOTES
# ============================================
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env to version control
# 3. Ensure .env is listed in .gitignore
# 4. Store production secrets in your deployment platform (Vercel, etc.)
# 5. Rotate all keys immediately if they are ever exposed
