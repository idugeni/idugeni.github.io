# ============================================
# SUPABASE — CLIENT (Frontend)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# ============================================
# SUPABASE — SERVER (Backend)
# ============================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here
SUPABASE_JWKS_URL=https://your-project-id.supabase.co/auth/v1/.well-known/jwks.json

# ============================================
# APPLICATION
# ============================================
ADMIN_EMAILS=your-admin-email@example.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ============================================
# EMAIL (RESEND)
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here
CONTACT_TO_EMAIL=owner@example.com
RESEND_FROM_EMAIL="Your Name <hello@example.com>"
CONTACT_AUTO_REPLY_ENABLED=false

# ============================================
# AI (GOOGLE GEMINI)
# ============================================
GOOGLE_GEMINI_API_KEY=your_google_ai_studio_key_here
GOOGLE_GEMINI_MODEL=gemini-1.5-flash

# ============================================
# SEO VERIFICATION
# ============================================
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-verification-code
NEXT_PUBLIC_BING_VERIFICATION=your-bing-verification-code
NEXT_PUBLIC_YANDEX_VERIFICATION=your-yandex-verification-code

# ============================================
# SECURITY NOTES
# ============================================
# 1. Copy this file to .env and fill in actual values
# 2. NEVER commit .env to version control
# 3. Store production secrets in deployment platform (Vercel, etc.)
